---
import { siteConfig } from '../data/site';

interface Props {
	title?: string;
}

const { title = siteConfig.name } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={siteConfig.description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="canonical" href="https://anthie.com.ar/" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
	</head>
	<body class="bg-base text-ink font-sans antialiased selection:bg-wine selection:text-white">
		<slot />
	</body>
</html>

<style is:global>
	/* Global smooth styles and utility overrides if needed */
	h1, h2, h3, h4, h5, h6 {
		font-family: 'Playfair Display', serif;
	}
</style>
